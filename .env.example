# ─── Database ───────────────────────────────────────
POSTGRES_USER=notetaker
POSTGRES_PASSWORD=notetaker_secret
POSTGRES_DB=ai_notetaker
DATABASE_URL=postgresql+asyncpg://notetaker:notetaker_secret@postgres:5432/ai_notetaker

# ─── Redis ──────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── MinIO (S3-compatible audio storage) ────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=meeting-audio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret

# ─── Auth ───────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Microsoft OAuth
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common

# ─── AI / Transcription ────────────────────────────
DEEPGRAM_API_KEY=your-deepgram-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ─── Frontend ──────────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret
NEXT_PUBLIC_API_URL=http://localhost:80
NEXT_PUBLIC_WS_URL=ws://localhost:80

# ─── Service Ports ─────────────────────────────────
AUTH_SVC_PORT=8001
MEETING_SVC_PORT=8002
TRANSCRIPT_SVC_PORT=8003
AI_SVC_PORT=8004
PROJECT_SVC_PORT=8005
TASK_SVC_PORT=8006
