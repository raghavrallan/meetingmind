# ─── Database ───────────────────────────────────────
POSTGRES_USER=notetaker
POSTGRES_PASSWORD=notetaker_secret
POSTGRES_DB=ai_notetaker
DATABASE_URL=postgresql+asyncpg://notetaker:notetaker_secret@postgres:5432/ai_notetaker

# ─── Redis ──────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── MinIO (S3-compatible audio storage) ────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_secret
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=meeting-audio
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_secret

# ─── Auth ───────────────────────────────────────────
JWT_SECRET=your-jwt-secret-change-me
JWT_ALGORITHM=HS256

# ─── Vault (AES-256-GCM master key) ────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# If empty, falls back to JWT_SECRET (not recommended for production)
VAULT_MASTER_KEY=

# ─── Google OAuth (optional) ────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Microsoft OAuth (optional) ─────────────────────
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# ─── AI / Transcription API Keys ────────────────────
# These are used ONLY for initial vault seeding on first boot.
# After seeding, keys are stored AES-256-GCM encrypted in the
# platform_keys database table. Manage via admin API after that.
DEEPGRAM_API_KEY=your-deepgram-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# ─── Frontend ──────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost
