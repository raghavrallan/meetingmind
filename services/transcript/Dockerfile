FROM python:3.12-slim

WORKDIR /app

COPY services/transcript/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY shared/ ./shared/
COPY services/transcript/ ./services/transcript/

ENV PYTHONPATH=/app

CMD ["uvicorn", "services.transcript.app.main:app", "--host", "0.0.0.0", "--port", "8003"]
