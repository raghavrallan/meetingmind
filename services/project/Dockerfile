FROM python:3.12-slim
WORKDIR /app
COPY services/project/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY shared/ ./shared/
COPY services/project/ ./services/project/
ENV PYTHONPATH=/app
CMD ["uvicorn", "services.project.app.main:app", "--host", "0.0.0.0", "--port", "8005"]
